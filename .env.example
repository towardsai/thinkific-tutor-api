# Path to the existing ai-tutor-app repo when running locally.
# In Docker this is usually /opt/ai-tutor-app.
AI_TUTOR_APP_PATH=/Users/louis/Documents/GitHub/ai-tutor-app

# Thinkific gating.
THINKIFIC_ALLOWED_ORIGINS=https://academy.towardsai.net
THINKIFIC_ALLOWED_HOSTS=academy.towardsai.net
THINKIFIC_REQUIRE_LOGGED_IN_USER=true
THINKIFIC_BLOCKED_LESSON_KEYWORDS=quiz,quizz,exam,assessment

# Defaults are derived from ai-tutor-app's course source registry.
# Override or add Thinkific course ids once you know them:
# THINKIFIC_COURSE_ID_SOURCE_MAP={"123456":"full_stack_ai_engineering","234567":"agentic_ai_engineering"}
# THINKIFIC_COURSE_URL_SOURCE_MAP={"https://academy.towardsai.net/courses/custom-slug":"full_stack_ai_engineering"}

# Model and tool cost controls.
THINKIFIC_TUTOR_MODEL=google-genai:gemini-2.5-flash
THINKIFIC_ENABLED_TOOLS=
THINKIFIC_DISABLE_KB=true
THINKIFIC_RETRIEVAL_BUDGET=24000
THINKIFIC_MEMORY_PRESET=

# Rate limits. These are in-memory per API process.
THINKIFIC_RATE_LIMIT_PER_MINUTE=6
THINKIFIC_RATE_LIMIT_PER_DAY=120
THINKIFIC_GLOBAL_RATE_LIMIT_PER_MINUTE=120

# Optional Opik usage monitoring.
OPIK_ENABLED=false
OPIK_PROJECT_NAME=towards-ai-thinkific-tutor
OPIK_WORKSPACE=
OPIK_API_KEY=
OPIK_MAX_TEXT_CHARS=8000

# Request/context caps.
THINKIFIC_MAX_BODY_BYTES=524288
THINKIFIC_MAX_PAGE_CONTEXT_CHARS=6000

# Public signed-out sales helper.
HELPER_ALLOWED_ORIGINS=https://academy.towardsai.net,https://towardsai.net,https://www.towardsai.net
HELPER_ALLOWED_HOSTS=academy.towardsai.net,towardsai.net,www.towardsai.net
HELPER_MODEL=gemini-2.5-flash
HELPER_MAX_OUTPUT_TOKENS=420
HELPER_RATE_LIMIT_PER_MINUTE=8
HELPER_RATE_LIMIT_PER_DAY=50
HELPER_IP_RATE_LIMIT_PER_MINUTE=60
HELPER_IP_RATE_LIMIT_PER_DAY=300
HELPER_GLOBAL_RATE_LIMIT_PER_MINUTE=120
HELPER_MAX_QUERY_CHARS=600
HELPER_MAX_HISTORY_TURNS=8
HELPER_OPIK_ENABLED=true
HELPER_OPIK_PROJECT_NAME=towards-ai-helper
HELPER_OPIK_MAX_TEXT_CHARS=4000

# Reused from ai-tutor-app/.env if not set here.
GEMINI_API_KEY=
COHERE_API_KEY=
HF_TOKEN=
